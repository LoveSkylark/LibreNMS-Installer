#!/usr/bin/env bash
set -euo pipefail

# Define variables
K3S_INSTALL_SCRIPT="https://get.k3s.io"
K9S_INSTALL_SCRIPT="https://webi.sh/k9s"
HELM_INSTALL_SCRIPT="https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3"
BIN_DIR="${BIN_DIR:-/usr/local/bin}"
LNMS_DIR="${LNMS_DIR:-/data}"
LNMS_HELM_BRANCH="${LNMS_HELM_BRANCH:-main}"
ENABLE_WEATHERMAP="${ENABLE_WEATHERMAP:-false}"
K3S_CHANNEL="${K3S_CHANNEL:-stable}"
K3S_VERSION="${K3S_VERSION:-}"
K9S_VERSION="${K9S_VERSION:-}"
HELM_VERSION="${HELM_VERSION:-}"
DRY_RUN=0
SKIP_UPGRADE=0

usage() {
    cat <<'EOF'
Usage: ./LibreNMS-Install [options]

Options:
  --dry-run         Print actions without making changes
  --skip-upgrade    Skip apt-get upgrade
  --help            Show this help
EOF
}

run_cmd() {
    if [ "$DRY_RUN" -eq 1 ]; then
        printf '[dry-run]'
        printf ' %q' "$@"
        printf '\n'
        return 0
    fi
    "$@"
}

run_pipe() {
    local command_str="$1"
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "[dry-run] $command_str"
        return 0
    fi
    bash -o pipefail -c "$command_str"
}

normalize_bool() {
    local raw="${1:-}"
    raw=$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]')
    case "$raw" in
        true|yes|on|1)
            echo "true"
            ;;
        *)
            echo "false"
            ;;
    esac
}

prepare_tls_requirements_from_values() {
    local cfg="$LNMS_DIR/lnms-config.yaml"
    local ingress_https=""
    local tls_existing_secret_name=""
    local le_enabled=""

    if [ ! -f "$cfg" ]; then
        echo "Skipping TLS prerequisites: values file not found at $cfg"
        return 0
    fi

    ingress_https=$(awk '
        /^ingress:[[:space:]]*$/ { in_ingress=1; next }
        in_ingress && /^[^[:space:]]/ { in_ingress=0 }
        in_ingress && /^[[:space:]]{2}https:[[:space:]]*/ {
            val=$2
            gsub(/"/, "", val)
            print val
            exit
        }
    ' "$cfg" 2>/dev/null)

    tls_existing_secret_name=$(awk '
        /^ingress:[[:space:]]*$/ { in_ingress=1; next }
        in_ingress && /^[^[:space:]]/ { in_ingress=0 }
        in_ingress && /^[[:space:]]{2}tls:[[:space:]]*$/ { in_tls=1; next }
        in_ingress && in_tls && /^[[:space:]]{2}[A-Za-z0-9_]+:[[:space:]]*$/ { in_tls=0 }
        in_tls && /^[[:space:]]{4}existingSecretName:[[:space:]]*/ {
            val=substr($0, index($0, ":") + 1)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
            gsub(/^"|"$/, "", val)
            print val
            exit
        }
    ' "$cfg" 2>/dev/null)

    le_enabled=$(awk '
        /^ingress:[[:space:]]*$/ { in_ingress=1; next }
        in_ingress && /^[^[:space:]]/ { in_ingress=0 }
        in_ingress && /^[[:space:]]{2}letsEncrypt:[[:space:]]*$/ { in_le=1; next }
        in_ingress && in_le && /^[[:space:]]{2}[A-Za-z0-9_]+:[[:space:]]*$/ { in_le=0 }
        in_le && /^[[:space:]]{4}enabled:[[:space:]]*/ {
            val=$2
            gsub(/"/, "", val)
            print val
            exit
        }
    ' "$cfg" 2>/dev/null)

    if [ "$(normalize_bool "$ingress_https")" != "true" ]; then
        echo "Skipping cert-manager setup: ingress.https is not enabled."
        return 0
    fi

    if [ -n "$tls_existing_secret_name" ]; then
        echo "Skipping cert-manager setup: ingress.tls.existingSecretName is set ($tls_existing_secret_name)."
        return 0
    fi

    if [ "$(normalize_bool "$le_enabled")" != "true" ]; then
        echo "Skipping cert-manager setup: ingress.letsEncrypt.enabled is not enabled."
        return 0
    fi

    echo "Preparing cert-manager controller from values file..."

    if [ "$DRY_RUN" -eq 1 ]; then
        echo "[dry-run] kubectl get namespace cert-manager || kubectl create namespace cert-manager"
    elif ! kubectl get namespace cert-manager >/dev/null 2>&1; then
        kubectl create namespace cert-manager >/dev/null || return 1
    fi

    run_cmd helm repo add jetstack https://charts.jetstack.io
    run_cmd helm repo update

    if [ "$DRY_RUN" -eq 1 ]; then
        echo "[dry-run] helm status cert-manager -n cert-manager && helm upgrade cert-manager jetstack/cert-manager -n cert-manager --set crds.enabled=true --wait --timeout 5m || helm install cert-manager jetstack/cert-manager -n cert-manager --set crds.enabled=true --wait --timeout 5m"
    elif helm status cert-manager -n cert-manager >/dev/null 2>&1; then
        helm upgrade cert-manager jetstack/cert-manager -n cert-manager --set crds.enabled=true --wait --timeout 5m
    else
        helm install cert-manager jetstack/cert-manager -n cert-manager --set crds.enabled=true --wait --timeout 5m
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
        echo "[dry-run] kubectl rollout status deployment/cert-manager -n cert-manager --timeout=180s"
        echo "[dry-run] kubectl rollout status deployment/cert-manager-cainjector -n cert-manager --timeout=180s"
        echo "[dry-run] kubectl rollout status deployment/cert-manager-webhook -n cert-manager --timeout=180s"
    else
        kubectl rollout status deployment/cert-manager -n cert-manager --timeout=180s
        kubectl rollout status deployment/cert-manager-cainjector -n cert-manager --timeout=180s
        kubectl rollout status deployment/cert-manager-webhook -n cert-manager --timeout=180s
    fi

    echo "cert-manager ready. Issuer/ClusterIssuer and Certificate resources should be managed by LibreNMS-Helm templates."
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            ;;
        --skip-upgrade)
            SKIP_UPGRADE=1
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            echo "Error: unknown option '$1'"
            usage
            exit 1
            ;;
    esac
    shift
done

# Start of the script
echo "################## Updating Linux ##################"
echo ""
run_cmd sudo apt-get update
if [ "$SKIP_UPGRADE" -eq 1 ]; then
    echo "Skipping apt upgrade (--skip-upgrade)."
else
    run_cmd sudo NEEDRESTART_MODE=a apt-get upgrade --yes
fi


echo ""
echo "################## Installing essential tools ##################"
echo ""
run_cmd sudo NEEDRESTART_MODE=a apt-get install -y curl git vim snmp snmpd


echo ""
echo "################## Downloading and installing K3S ##################"
echo ""
echo "This step installs K3s, a lightweight Kubernetes distribution."
echo ""
# Set KUBECONFIG for all users by creating a script in /etc/profile.d/
if [ "$DRY_RUN" -eq 1 ]; then
    echo "[dry-run] sudo grep -qxF 'KUBECONFIG=\"/etc/rancher/k3s/k3s.yaml\"' /etc/environment || echo 'KUBECONFIG=\"/etc/rancher/k3s/k3s.yaml\"' | sudo tee -a /etc/environment >/dev/null"
elif ! sudo grep -qxF 'KUBECONFIG="/etc/rancher/k3s/k3s.yaml"' /etc/environment; then
    run_pipe "echo 'KUBECONFIG=\"/etc/rancher/k3s/k3s.yaml\"' | sudo tee -a /etc/environment >/dev/null"
fi
export KUBECONFIG=/etc/rancher/k3s/k3s.yaml
if [ -n "$K3S_VERSION" ]; then
    run_pipe "curl -fsSL '$K3S_INSTALL_SCRIPT' | sudo INSTALL_K3S_BIN_DIR='$BIN_DIR' INSTALL_K3S_CHANNEL='$K3S_CHANNEL' INSTALL_K3S_VERSION='$K3S_VERSION' sh -"
else
    run_pipe "curl -fsSL '$K3S_INSTALL_SCRIPT' | sudo INSTALL_K3S_BIN_DIR='$BIN_DIR' INSTALL_K3S_CHANNEL='$K3S_CHANNEL' sh -"
fi

if [ "$DRY_RUN" -eq 1 ]; then
    echo "[dry-run] Skipping K3s service/API readiness checks."
else
    echo "Waiting for K3s service to become active..."
    k3s_service_ready=0
    for _ in $(seq 1 30); do
        if sudo systemctl is-active --quiet k3s; then
            k3s_service_ready=1
            break
        fi
        sleep 2
    done

    if [ "$k3s_service_ready" -ne 1 ]; then
        echo "Error: K3s service did not become active in time."
        sudo systemctl status k3s --no-pager || true
        exit 1
    fi

    echo "Waiting for Kubernetes API readiness..."
    k3s_api_ready=0
    for _ in $(seq 1 45); do
        if sudo k3s kubectl get nodes >/dev/null 2>&1; then
            k3s_api_ready=1
            break
        fi
        sleep 2
    done

    if [ "$k3s_api_ready" -ne 1 ]; then
        echo "Error: Kubernetes API did not become ready in time."
        sudo k3s kubectl get nodes -o wide || true
        exit 1
    fi

    sudo k3s kubectl get nodes -o wide
fi
echo ""


echo "################## Downloading and installing K9S ##################"
echo ""
echo "This step installs K9s, a terminal-based Kubernetes dashboard."
echo ""

# make K9S usable by all users
if [ -n "$K9S_VERSION" ]; then
    K9S_ARCH=$(uname -m)
    case "$K9S_ARCH" in
        x86_64|amd64)
            K9S_ARCH="amd64"
            ;;
        aarch64|arm64)
            K9S_ARCH="arm64"
            ;;
        *)
            echo "Error: unsupported architecture for pinned K9s install: $K9S_ARCH"
            exit 1
            ;;
    esac

    TMP_K9S_DIR=$(mktemp -d)
    run_cmd curl -fsSL -o "$TMP_K9S_DIR/k9s.tar.gz" "https://github.com/derailed/k9s/releases/download/v${K9S_VERSION#v}/k9s_Linux_${K9S_ARCH}.tar.gz"
    run_cmd tar -xzf "$TMP_K9S_DIR/k9s.tar.gz" -C "$TMP_K9S_DIR"
    run_cmd sudo install -m 0755 "$TMP_K9S_DIR/k9s" "$BIN_DIR/k9s"
    run_cmd rm -rf "$TMP_K9S_DIR"
else
    run_pipe "curl -fsSL '$K9S_INSTALL_SCRIPT' | sh -"
    K9S_PATH=$(command -v k9s || true)
    if [ -z "$K9S_PATH" ] && [ -x "$HOME/.local/bin/k9s" ]; then
        K9S_PATH="$HOME/.local/bin/k9s"
    fi

    if [ "$DRY_RUN" -eq 0 ] && [ -z "$K9S_PATH" ]; then
        echo "Error: k9s binary not found after install."
        exit 1
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
        echo "[dry-run] sudo install -m 0755 <k9s_path> $BIN_DIR/k9s"
    else
        if [ "$K9S_PATH" = "$BIN_DIR/k9s" ]; then
            echo "k9s already installed at $BIN_DIR/k9s; skipping copy."
        else
            run_cmd sudo install -m 0755 "$K9S_PATH" "$BIN_DIR/k9s"
        fi
    fi
fi

if [ "$DRY_RUN" -eq 0 ] && [ ! -x "$BIN_DIR/k9s" ]; then
    echo "Error: k9s install failed; binary missing at $BIN_DIR/k9s"
    exit 1
fi

if [ "$DRY_RUN" -eq 1 ]; then
    echo "[dry-run] $BIN_DIR/k9s version | head -n 1"
else
    "$BIN_DIR/k9s" version | head -n 1 || true
fi

echo "################## Downloading and installing Helm ##################"
echo ""
echo "This step installs Helm, the Kubernetes package manager."
echo ""
if [ -n "$HELM_VERSION" ]; then
    run_pipe "curl -fsSL '$HELM_INSTALL_SCRIPT' | sudo DESIRED_VERSION='v${HELM_VERSION#v}' bash"
else
    run_pipe "curl -fsSL '$HELM_INSTALL_SCRIPT' | sudo bash"
fi
echo ""

echo "################## Fetching LibreNMS Helm Repo ##################"
echo ""
echo "This step fetches the LibreNMS Helm chart from the repository."
echo ""
run_cmd sudo mkdir -p "$LNMS_DIR/chart" "$LNMS_DIR/vault" "$LNMS_DIR/certs"

if [ ! -d "$LNMS_DIR/vault/LibreNMS-Helm/.git" ]; then
    run_cmd sudo git clone --branch "$LNMS_HELM_BRANCH" https://github.com/LoveSkylark/LibreNMS-Helm.git "$LNMS_DIR/vault/LibreNMS-Helm"
else
    run_cmd sudo git -C "$LNMS_DIR/vault/LibreNMS-Helm" fetch origin
    run_cmd sudo git -C "$LNMS_DIR/vault/LibreNMS-Helm" checkout "$LNMS_HELM_BRANCH"
    run_cmd sudo git -C "$LNMS_DIR/vault/LibreNMS-Helm" pull --ff-only origin "$LNMS_HELM_BRANCH"
fi

if [ ! -d "$LNMS_DIR/vault/LibreNMS-Installer/.git" ]; then
    run_cmd sudo git clone https://github.com/LoveSkylark/LibreNMS-Installer.git "$LNMS_DIR/vault/LibreNMS-Installer"
else
    run_cmd sudo git -C "$LNMS_DIR/vault/LibreNMS-Installer" pull --ff-only
fi

if [ "$ENABLE_WEATHERMAP" = "true" ]; then
    if [ ! -d "$LNMS_DIR/vault/LibreNMS-Weathermap-template/.git" ]; then
        run_cmd sudo git clone https://github.com/LoveSkylark/LibreNMS-Weathermap-template.git "$LNMS_DIR/vault/LibreNMS-Weathermap-template"
    else
        run_cmd sudo git -C "$LNMS_DIR/vault/LibreNMS-Weathermap-template" pull --ff-only
    fi
else
    echo "Skipping Weathermap template repository sync (ENABLE_WEATHERMAP=$ENABLE_WEATHERMAP)."
fi

echo "################## Fetching Config ##################"
echo ""
echo "  "
echo ""
if [ ! -f "$LNMS_DIR/lnms-config.yaml" ]; then
    run_cmd sudo cp "$LNMS_DIR/vault/LibreNMS-Installer/config/lnms-config.yaml" "$LNMS_DIR/lnms-config.yaml"
fi
if [ "$ENABLE_WEATHERMAP" = "true" ]; then
    if [ ! -d "$LNMS_DIR/librenms/application/weathermap/templates" ]; then
        run_cmd sudo mkdir -p "$LNMS_DIR/librenms/application/weathermap/templates"
    fi
    if [ -z "$(ls -A "$LNMS_DIR/librenms/application/weathermap/templates" 2>/dev/null)" ]; then
        run_cmd sudo cp -r "$LNMS_DIR/vault/LibreNMS-Weathermap-template"/* "$LNMS_DIR/librenms/application/weathermap/"
    fi
else
    echo "Skipping Weathermap config population (ENABLE_WEATHERMAP=$ENABLE_WEATHERMAP)."
fi

echo ""
echo "################## Preparing TLS Prerequisites ##################"
echo ""
echo "This step bootstraps cert-manager (cluster prerequisite) from lnms-config.yaml when needed."
echo ""
prepare_tls_requirements_from_values

echo ""

echo "################## Adding aliases for KUBE & HELM ##################"
echo ""
echo "This step sets up convenient aliases for managing Kubernetes and Helm."
echo ""
run_cmd sudo cp -r "$LNMS_DIR/vault/LibreNMS-Installer/profile.d"/* /etc/profile.d/
echo ""


echo "################## Setting up SNMP for LibreNMS ##################"
echo ""
echo "This step configures SNMP for LibreNMS monitoring."
echo ""
run_cmd curl -fsSL -o /tmp/librenms-distro https://raw.githubusercontent.com/librenms/librenms-agent/master/snmp/distro
run_cmd sudo install -m 0755 /tmp/librenms-distro /usr/bin/distro
run_cmd rm -f /tmp/librenms-distro
run_cmd sudo cp "$LNMS_DIR/vault/LibreNMS-Installer/snmpd.conf.d/snmp.conf" /etc/snmp/snmpd.conf.d/snmp.conf
run_cmd sudo systemctl restart snmpd
run_cmd sudo systemctl enable snmpd
echo ""


if [ -f "/etc/profile.d/nms.sh" ]; then
    # Prefer the installed profile script path.
    # shellcheck disable=SC1091
    source "/etc/profile.d/nms.sh"
elif [ -f "$LNMS_DIR/vault/LibreNMS-Installer/profile.d/nms.sh" ]; then
    # Load nms() in this shell so no new terminal is required.
    # shellcheck disable=SC1090
    source "$LNMS_DIR/vault/LibreNMS-Installer/profile.d/nms.sh"
else
    echo "Warning: nms profile script not found in /etc/profile.d"
fi

echo "################## Installation Complete ##################"
echo ""
echo "LibreNMS cluster is installed and configured successfully."
echo ""
echo "Run 'nms start' to start the LibreNMS cluster"